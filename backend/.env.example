# OpenAI API Configuration
OPENAI_API_KEY=your_openai_api_key_here

# Hugging Face API (optional)
HF_API_KEY=your_hf_api_key_here

# CORS Configuration
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# Database Configuration
USE_DATABASE=true

# N8tive Portal Auth — must match N8TIVE_JWT_SECRET in the Company Portal backend
N8TIVE_JWT_SECRET=replace-with-the-same-secret-as-the-portal
N8TIVE_JWT_ISSUER=n8tive-portal
N8TIVE_JWT_AUDIENCE=n8tive-suite







